{"id":"f438b438-6e1b-48e7-9ad0-fac6f2b9913a","title":"Thomas Davis (JSON Resume)","category":"imported","thumbnail":"http://10.213.59.1:8000/media/templates/previews/template_f438b4386e1b48e79ad0fac6f2b9913a.jpg","thumbnail_url":"http://10.213.59.1:8000/media/templates/previews/template_f438b4386e1b48e79ad0fac6f2b9913a.jpg","form_schema":{},"preview_image":"http://10.213.59.1:8000/media/templates/previews/template_f438b4386e1b48e79ad0fac6f2b9913a.jpg","html_structure":"\n<div id=\"resume-editor\">\n  <h1>{{ resume.basics.name }}</h1>\n  <p>{{ resume.basics.summary }}</p>\n\n  <!-- Hidden JSON payload for the resume. Editors can replace this with a dynamic editor. -->\n  <textarea id=\"resume-json\" style=\"display:none\">{}</textarea>\n\n  <div style=\"margin-top:12px\">\n    <button id=\"ai-generate-bullets\">AI Generate Bullets</button>\n    <button id=\"ai-generate-summary\">AI Generate Summary</button>\n    <button id=\"ai-improve-section\">AI Improve Section</button>\n    <button id=\"ai-suggest-skills\">AI Suggest Skills</button>\n    <button id=\"preview-button\">Preview</button>\n  </div>\n\n  <div id=\"ai-status\" style=\"margin-top:8px;color:#333\"></div>\n\n  <div id=\"preview-area\" style=\"border:1px solid #eee;margin-top:12px;padding:12px\"></div>\n</div>\n\n<script>\n  function getCookie(name) {\n    const v = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');\n    return v ? v.pop() : '';\n  }\n\n  function postJSON(url, payload){\n    return fetch(url, {\n      method: 'POST',\n      headers: {\n        'Content-Type': 'application/json',\n        'X-Requested-With': 'XMLHttpRequest',\n        'X-CSRFToken': getCookie('csrftoken'),\n      },\n      body: JSON.stringify(payload),\n    }).then(r => r.json());\n  }\n\n  function showStatus(msg){\n    const el = document.getElementById('ai-status');\n    if(el) el.textContent = msg;\n  }\n\n  document.addEventListener('DOMContentLoaded', function(){\n    const jsonArea = document.getElementById('resume-json');\n    // Ensure resume JSON is present\n    if(jsonArea && jsonArea.value.trim() === '{}'){\n      try{ jsonArea.value = JSON.stringify(window.resume || {}); }catch(e){ jsonArea.value = '{}'; }\n    }\n\n    const templatePreviewUrl = '/api/v1/exports/templates/f438b438-6e1b-48e7-9ad0-fac6f2b9913a/preview/';\n\n    document.getElementById('ai-generate-summary').addEventListener('click', async function(){\n      showStatus('Queuing summary generation...');\n      const payload = { role: (window.resume && window.resume.basics && window.resume.basics.label) || '' };\n      const res = await postJSON('/api/v1/ai/generate-summary/', payload);\n      showStatus(res.task_id ? 'Task queued: ' + res.task_id : JSON.stringify(res));\n    });\n\n    document.getElementById('ai-generate-bullets').addEventListener('click', async function(){\n      showStatus('Queuing bullets generation...');\n      const resume = JSON.parse(jsonArea.value || '{}');\n      const experience = (resume.work || resume.experience) || [];\n      const res = await postJSON('/api/v1/ai/generate-bullets/', { experience });\n      showStatus(res.task_id ? 'Task queued: ' + res.task_id : JSON.stringify(res));\n    });\n\n    document.getElementById('ai-improve-section').addEventListener('click', async function(){\n      showStatus('Queuing section improvement...');\n      const resume = JSON.parse(jsonArea.value || '{}');\n      const text = (resume.basics && resume.basics.summary) || '';\n      const res = await postJSON('/api/v1/ai/improve-section/', { text: text, section_name: 'summary' });\n      showStatus(res.task_id ? 'Task queued: ' + res.task_id : JSON.stringify(res));\n    });\n\n    document.getElementById('ai-suggest-skills').addEventListener('click', async function(){\n      showStatus('Queuing skill suggestions...');\n      const resume = JSON.parse(jsonArea.value || '{}');\n      const role = (resume.basics && resume.basics.label) || '';\n      const existing_skills = (resume.skills && resume.skills.map(s=>s.name)) || [];\n      const res = await postJSON('/api/v1/ai/suggest-skills/', { role, existing_skills });\n      showStatus(res.task_id ? 'Task queued: ' + res.task_id : JSON.stringify(res));\n    });\n\n    document.getElementById('preview-button').addEventListener('click', async function(){\n      showStatus('Rendering preview...');\n      const resume = JSON.parse(jsonArea.value || '{}');\n      try{\n        const resp = await fetch(templatePreviewUrl.replace('f438b438-6e1b-48e7-9ad0-fac6f2b9913a', 'f438b438-6e1b-48e7-9ad0-fac6f2b9913a'), {\n          method: 'POST',\n          headers: {\n            'Content-Type': 'application/json',\n            'X-CSRFToken': getCookie('csrftoken'),\n          },\n          body: JSON.stringify({ data: resume })\n        });\n        const html = await resp.text();\n        document.getElementById('preview-area').innerHTML = html;\n        showStatus('Preview rendered.');\n      }catch(e){ showStatus('Preview failed: ' + e); }\n    });\n  });\n</script>\n","css":"","metadata":{"form_schema":{}},"created_at":"2026-04-28T21:35:46.673124Z","updated_at":"2026-04-28T21:53:32.848002Z"}

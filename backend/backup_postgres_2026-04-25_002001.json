{
  "model": "resume.resumetemplate",
  "pk": "4ba7bb19-6408-4d41-aff9-e09e1831b005",
  "fields": {
    "created_at": "2026-04-24T18:25:20.418Z",
    "updated_at": "2026-04-24T18:25:20.418Z",
    "name": "Professional Simple",
    "preview_image": "",
    "html_structure": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"UTF-8\">\n    <style>\n        body {\n            font-family: Arial, sans-serif;\n            margin: 40px;\n            color: #222;\n        }\n\n        h1 {\n            font-size: 28px;\n            margin-bottom: 2px;\n        }\n\n        h2 {\n            font-size: 18px;\n            border-bottom: 1px solid #000;\n            margin-top: 20px;\n            padding-bottom: 4px;\n        }\n\n        .subheading {\n            font-size: 14px;\n            margin-bottom: 10px;\n        }\n\n        p {\n            margin: 4px 0;\n        }\n\n        .section {\n            margin-bottom: 12px;\n        }\n\n        .item {\n            margin-bottom: 8px;\n        }\n\n        .bold {\n            font-weight: bold;\n        }\n\n        ul {\n            padding-left: 18px;\n        }\n\n        .header {\n            margin-bottom: 10px;\n        }\n    </style>\n</head>\n\n<body>\n\n    <div class=\"header\">\n        <h1>{{ resume.personal_info.name }}</h1>\n        <p class=\"subheading\">{{ resume.personal_info.role }}</p>\n        <p>{{ resume.personal_info.phone }} | {{ resume.personal_info.email }} | {{ resume.personal_info.linkedin }} | {{ resume.personal_info.github }}</p>\n    </div>\n\n    <div class=\"section\">\n        <h2>Summary</h2>\n        <p>{{ resume.personal_info.summary }}</p>\n    </div>\n\n    <div class=\"section\">\n        <h2>Skills</h2>\n        <ul>\n            {% for skill in resume.skills %}\n                <li>{{ skill }}</li>\n            {% endfor %}\n        </ul>\n    </div>\n\n    <div class=\"section\">\n        <h2>Projects</h2>\n        {% for project in resume.projects %}\n            <div class=\"item\">\n                <p class=\"bold\">{{ project.title }}</p>\n                <p>{{ project.description }}</p>\n            </div>\n        {% endfor %}\n    </div>\n\n    <div class=\"section\">\n        <h2>Certifications & Achievements</h2>\n        <ul>\n            {% for certification in resume.certifications %}\n                <li>{{ certification }}</li>\n            {% endfor %}\n        </ul>\n    </div>\n\n    <div class=\"section\">\n        <h2>Education</h2>\n        {% for edu in resume.education %}\n            <div class=\"item\">\n                <p class=\"bold\">{{ edu.degree }}</p>\n                <p>{{ edu.institution }}{% if edu.year %} | {{ edu.year }}{% endif %}</p>\n            </div>\n        {% endfor %}\n    </div>\n\n</body>\n</html>\n",
    "is_active": true
  }
},
